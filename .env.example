# URL de base (https://www.votredomaine.be en prod)
NEXT_PUBLIC_BASE_URL=http://localhost:3000

# Supabase
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# Mollie (paiements) — clé test sur dashboard.mollie.com
MOLLIE_API_KEY=

# Resend (emails transactionnels)
RESEND_API_KEY=

# Cron RGPD — secret partagé entre Next.js et la Supabase Edge Function
CRON_SECRET=

# Sentry (monitoring)
NEXT_PUBLIC_SENTRY_DSN=
SENTRY_DSN=
SENTRY_AUTH_TOKEN=
