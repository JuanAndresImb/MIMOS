# URL de base (https://www.mimos.be en prod)
NEXT_PUBLIC_BASE_URL=http://localhost:3000

# Supabase — clés sur : supabase.com/dashboard/project/<ref>/settings/api
# "publishable key" = anciennement "anon key" (safe côté client)
# "secret key"      = anciennement "service_role" (backend uniquement, ne jamais exposer)
NEXT_PUBLIC_SUPABASE_URL=https://<project-ref>.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=        # publishable key (sb_publishable_... ou eyJ...)
SUPABASE_SERVICE_ROLE_KEY=            # secret key     (sb_secret_...)

# Mollie (paiements) — clé test sur dashboard.mollie.com
MOLLIE_API_KEY=test_...

# Resend (emails transactionnels) — resend.com/api-keys
RESEND_API_KEY=re_...

# Cron RGPD — chaîne aléatoire, même valeur dans Vercel + ici
CRON_SECRET=

# bpost webhook — portail MyBusiness > Webhooks > Secret
BPOST_WEBHOOK_SECRET=

# Sentry (monitoring) — sentry.io/settings/<org>/projects/<project>/keys/
NEXT_PUBLIC_SENTRY_DSN=
SENTRY_DSN=
SENTRY_AUTH_TOKEN=
