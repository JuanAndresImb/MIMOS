{
  "framework": "nextjs",
  "buildCommand": "pnpm build",
  "installCommand": "pnpm install --frozen-lockfile",
  "git": {
    "deploymentEnabled": {
      "main": true
    }
  },
  "crons": [
    {
      "path": "/api/cron/anonymize-expired",
      "schedule": "0 2 * * *"
    },
    {
      "path": "/api/cron/expire-b2b-payments",
      "schedule": "0 6 * * 1-5"
    }
  ]
}
